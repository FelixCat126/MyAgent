{
  "name": "myagent",
  "version": "1.0.0",
  "description": "本地AI助手 - 跨平台、多模型、多模态智能对话工具",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "ELECTRON_DISABLE_SECURITY_WARNINGS=true vite",
    "test": "npx vitest run",
    "build": "tsc && vite build",
    "preview": "ELECTRON_DISABLE_SECURITY_WARNINGS=true vite preview",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "generate:icon": "bash scripts/generate-app-icon.sh",
    "build:icon-default": "node scripts/build-default-icon.mjs"
  },
  "keywords": [
    "ai",
    "chat",
    "assistant",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "antd": "^5.13.2",
    "axios": "^1.6.5",
    "dayjs": "^1.11.10",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.0",
    "mammoth": "^1.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "zustand": "^4.5.0"
  },
  "electron": {
    "preload": {
      "type": "commonjs"
    }
  }
}
